generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Language {
  UK
  EN
  DE
}

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  passwordHash  String
  name          String?
  xp            Int       @default(0)
  streak        Int       @default(0)
  dailyGoal     Int       @default(20)
  lastStudiedAt DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  decks         Deck[]
  cards         Card[]
  studySessions StudySession[]
}

model Deck {
  id          String   @id @default(cuid())
  name        String
  description String?
  language    Language @default(UK)
  tags        String[] @default([])
  color       String   @default("yellow")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId String

  cards Card[]

  @@index([userId])
}

model Card {
  id       String   @id @default(cuid())
  question String
  answer   String
  notes    String?
  tags     String[] @default([])

  // FSRS state
  stability      Float?
  difficulty     Float?
  elapsedDays    Float     @default(0)
  scheduledDays  Float     @default(0)
  reps           Int       @default(0)
  lapses         Int       @default(0)
  state          Int       @default(0)
  due            DateTime  @default(now())
  lastReviewedAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId String

  deck   Deck   @relation(fields: [deckId], references: [id], onDelete: Cascade)
  deckId String

  @@index([userId])
  @@index([deckId])
}

model StudySession {
  id            String   @id @default(cuid())
  date          DateTime @db.Date
  cardsReviewed Int      @default(0)
  xpEarned      Int      @default(0)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId String

  @@unique([userId, date])
  @@index([userId])
}
